@page "/ListarAreas"

<div class="container py-3" data-testid="areas-list-page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <TituloPaginaComponent Texto="Listar areas" />
        <BotonVolverAtrasComponent />
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-semibold">Areas registradas</h5>
            <a class="btn btn-primary" href="/GestionarAreas" data-testid="area-create-btn">
                Registrar area
            </a>
        </div>
        <div class="card-body">
            <AlertaOperacionComponent Mensaje="@MensajeResultado" Exito="OperacionExitosa" CssAdicional="mb-3" />

            @if (Areas.Count == 0)
            {
                <div class="alert alert-secondary border text-center mb-0" data-testid="area-empty-state">
                    <h6 class="fw-semibold">Sin registros por mostrar</h6>
                    <p class="mb-2">Aun no hay datos disponibles para esta seccion.</p>
                    <a class="btn btn-primary" href="/GestionarAreas" data-testid="area-empty-create-btn">
                        Registrar area
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive border rounded">
                    <table class="table table-hover table-striped align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID area</th>
                                <th>Area</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var area in Areas)
                            {
                                <tr data-testid="@(value: $"area-row-{area.Id}")">
                                    <td>@area.Id</td>
                                    <td>@area.Nombre</td>
                                    <td>
                                        <div class="app-row-actions">
                                            <button class="btn btn-sm btn-outline-primary" 
                                                @onclick="() => ModificarArea(area.Id)">
                                                Modificar
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" 
                                                @onclick="() => EliminarArea(area.Id)">
                                                Elminar
                                            </button>
                                        </div>
                                        

                                        @* <AccionesComponent Id="@area.Id" 
                                            OnModificar="ModificarArea"
                                            OnEliminar="EliminarArea" /> *@
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <small class="text-muted">Mostrando @Areas.Count registros</small>
                </div>
            }
        </div>
    </div>
</div>